# =============================================================================
# Velvich Infra CRM — environment template
# Copy to .env and fill in. NEVER commit a real .env. No secrets in client code.
# =============================================================================

# --- Runtime ----------------------------------------------------------------
NODE_ENV=development
TZ=Asia/Kolkata

# --- API server -------------------------------------------------------------
API_PORT=4000
# Public origin of the web app, used for CORS + auth cookies + email links.
WEB_ORIGIN=http://localhost:3000
# Public base URL of the API itself (used by Better Auth + signed links).
API_ORIGIN=http://localhost:4000

# --- Database (PostgreSQL) --------------------------------------------------
POSTGRES_USER=velvich
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=velvich_crm
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://velvich:change-me-strong-password@localhost:5432/velvich_crm?schema=public

# --- Redis / BullMQ ---------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Auth (Better Auth) -----------------------------------------------------
# 32+ char random secret. Generate: openssl rand -base64 48
BETTER_AUTH_SECRET=replace-with-long-random-secret
BETTER_AUTH_URL=http://localhost:4000
# Session cookie lifetime (seconds). Default 7 days.
SESSION_MAX_AGE=604800

# --- Cloudflare R2 (S3-compatible, PRIVATE bucket) --------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=velvich-crm
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
# Signed URL lifetime for downloads (seconds).
R2_SIGNED_URL_TTL=300

# --- AI (Anthropic Claude) --------------------------------------------------
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-4-6
AI_MAX_TOKENS=2048
AI_TEMPERATURE=0
# Master switch — when false, AI endpoints degrade gracefully to manual forms.
AI_ENABLED=true

# --- Email (Resend) ---------------------------------------------------------
RESEND_API_KEY=
EMAIL_FROM="Velvich Infra CRM <noreply@velvichinfra.example>"

# --- Uploads / limits -------------------------------------------------------
MAX_UPLOAD_MB=25
RATE_LIMIT_AUTH_PER_MIN=10
RATE_LIMIT_AI_PER_MIN=20

# --- Web (Next.js) — only NEXT_PUBLIC_* reaches the browser -----------------
NEXT_PUBLIC_API_ORIGIN=http://localhost:4000
NEXT_PUBLIC_APP_NAME="Velvich Infra CRM"

# --- Backups ----------------------------------------------------------------
BACKUP_R2_BUCKET=velvich-crm-backups
BACKUP_RETENTION_DAYS=30
